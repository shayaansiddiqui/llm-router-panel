[Unit]
Description=LLM Gateway Console
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/var/www/llm-gateway-console/backend
EnvironmentFile=/var/www/llm-gateway-console/backend/.env
ExecStart=/var/www/llm-gateway-console/backend/.venv/bin/uvicorn app.main:app --host 127.0.0.1 --port 8010
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
